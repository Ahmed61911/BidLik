# Bidlik backend — same self-hosted Supabase project the webapp uses, deployed
# to a publicly reachable HTTPS host (a phone can't reach "localhost" on your
# dev machine). Fill these in from your deployed webapp/.env equivalents.

EXPO_PUBLIC_SUPABASE_URL=https://your-deployed-supabase-host
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Origin of the deployed webapp server — hosts the custom /api/storage/* and
# /api/public/cmi-* routes the mobile app also calls (see architecture plan §1/§3).
EXPO_PUBLIC_API_URL=https://your-deployed-webapp-origin
