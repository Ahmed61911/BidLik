# ============================================================================
# Local self-hosted Supabase — replaces the previous cloud project
# (gsqkggdpqchapfogqekp.supabase.co; credentials backed up in
# _backup_docker_pre_migration/root.env.bak).
#
# These values are generated by docker/gen-keys.cjs and MUST match
# docker/.env (JWT_SECRET in particular — ANON_KEY/SERVICE_ROLE_KEY are JWTs
# signed with it). If you regenerate docker/.env's keys, copy the new
# ANON_KEY here too.
# ============================================================================
SUPABASE_PROJECT_ID="local"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE3ODMxNjcwNzMsImV4cCI6MjA5ODUyNzA3M30.oy_fQz6DC86XHfo9tNH8mBtrVEQ1kU7u4Zy2_bTAPbo"
SUPABASE_URL="http://localhost:8000"
VITE_SUPABASE_PROJECT_ID="local"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE3ODMxNjcwNzMsImV4cCI6MjA5ODUyNzA3M30.oy_fQz6DC86XHfo9tNH8mBtrVEQ1kU7u4Zy2_bTAPbo"
VITE_SUPABASE_URL="http://localhost:8000"

# Service-role key — server-only (used by src/integrations/supabase/client.server.ts
# and the /api/public/* routes). Never add a VITE_ mirror of this.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTc4MzE2NzA3MywiZXhwIjoyMDk4NTI3MDczfQ.5cyo_WUfbs5cMgm-4iNWQ0_pSKPAvuM4tgqwmIjGOlw"

# Demo-account quick-seed endpoint — safe to enable for local dev only.
ALLOW_DEMO_SEED=true

# CMI payment gateway — left unset intentionally (as it was against the cloud
# project too). cmi-init.ts degrades gracefully to a "not configured" message
# without these; set them here if you have real/sandbox CMI merchant creds.
# CMI_CLIENT_ID=
# CMI_STORE_KEY=
# CMI_GATEWAY_URL=
APP_ORIGIN=http://localhost:8080

# Local filesystem storage (replaces Supabase Storage — see src/lib/storage).
# Running `bun run dev` directly on the host (not the Dockerized `app`
# service) has no /storage volume, so point this at a real host directory
# instead — matches docker/.dockerignore's docker/storage-data convention.
STORAGE_ROOT=./docker/local-storage
STORAGE_SIGNING_SECRET=fce5c10a5b6c0029ca71a6dc09b95b6bcc21b4133ab59706dc980c736bdbcb27
