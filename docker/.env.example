# ============================================================================
# BidLik local stack — copy to `docker/.env` and fill in generated secrets.
# Nothing here is a real secret; regenerate everything for any shared/staging
# deployment. Run `node gen-keys.cjs` from this docker/ folder to print fresh
# values for the JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY / SECRET_KEY_BASE
# block below.
# ============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_PORT=54322
POSTGRES_DB=postgres
# The supabase/postgres image applies THIS SAME password to every built-in
# role it ships with (postgres, supabase_admin, authenticator,
# supabase_auth_admin, supabase_storage_admin, ...) — verified empirically.
# There is no separate per-role password; do not invent one.
POSTGRES_PASSWORD=postgres_change_me

# --- JWT / keys --------------------------------------------------------------
# Generate all of these together with: node gen-keys.cjs
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
REALTIME_SECRET_KEY_BASE=
# Signs local storage download tokens (src/lib/storage/server/signing.server.ts).
# Not a Supabase key — unrelated to JWT_SECRET above, generated by the same script.
STORAGE_SIGNING_SECRET=

# --- Public URLs ------------------------------------------------------------
KONG_HTTP_PORT=8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:8080
APP_PORT=8080

# --- Real deployment overrides (VPS, staging, anything not on your own machine) ---
# Uncomment and set these to your public IP/domain. Without them, the app
# defaults to "kong.bidlik.local" which only resolves inside Docker's own
# network — an end user's browser can never reach it, so login (and every
# other API call) fails with ERR_CONNECTION_REFUSED. VITE_SUPABASE_URL is
# baked into the client bundle at build time, so changing it requires
# `docker compose up -d --build app`, not just a restart.
# VITE_SUPABASE_URL=http://<your-ip-or-domain>:8000
# SUPABASE_URL=http://<your-ip-or-domain>:8000
# APP_ORIGIN=http://<your-ip-or-domain>:8080

# --- Optional app-side flags (only read if you also run the `app` service or
#     point a host-run `bun dev` at this stack) -----------------------------
ALLOW_DEMO_SEED=true

# --- Local filesystem storage (replaces Supabase Storage — see src/lib/storage) ---
# Path is *inside the app container* when using the `app` service (backed by
# the "storage-files" volume); if running `bun run dev` on the host instead,
# point this at a real host directory, e.g. ./docker/storage-data.
STORAGE_ROOT=/storage
# Optional overrides — defaults are 10 MB for images, 8 MB for documents/PDFs
# (see src/lib/storage/validation.ts).
# STORAGE_MAX_IMAGE_BYTES=10485760
# STORAGE_MAX_DOCUMENT_BYTES=8388608
